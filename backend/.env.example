# --- Environment Settings ---
ENVIRONMENT=development
LOG_LEVEL=DEBUG
APP_NAME="SQLCopilot API Engine"

# --- LLM API Keys ---
# Lấy key tại: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_api_key_here

# --- Database Connection ---
# Format MySQL: mysql+pymysql://user:password@localhost:3306/db_name
# Format SQL Server: mssql+pyodbc://user:password@localhost/db_name?driver=ODBC+Driver+17+for+SQL+Server
LOCAL_DB_URL=mysql+pymysql://root:password123@localhost:3306/sample_db